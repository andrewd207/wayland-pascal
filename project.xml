<?xml version="1.0" encoding="UTF-8"?>
<project>
  <name>wayland</name>
  <version>0.1.0</version>
  <author>Andrew Haines</author>
  <license>BSD-3-Clause</license>

  <!-- Aggregator. Builds the pasbuild modules (RTL-only). The code generator
       (wayland-gen/) is now RTL-only too — its former tiOPF / json_easy
       dependency was removed by vendoring a small AST writer
       (wayland-gen/vendor) — so it builds with pasbuild like everything else. -->
  <build>
    <packaging>pom</packaging>
  </build>

  <modules>
    <module>wayland-rt</module>
    <module>wayland-stable</module>
    <module>wayland-unstable</module>
    <module>wayland-staging</module>
    <module>wayland-classes</module>
    <module>wayland-demo</module>
    <!-- Examples: excluded from the default build; built by `make examples`
         (or `pasbuild compile` with the all-modules flag). -->
    <module activeByDefault="false">wayland-examples</module>
    <!-- Code generator + its vendored AST writer. Build-time tools, so excluded
         from the default build; build explicitly to regenerate bindings. -->
    <module activeByDefault="false">wayland-gen/vendor</module>
    <module activeByDefault="false">wayland-gen</module>
  </modules>
</project>

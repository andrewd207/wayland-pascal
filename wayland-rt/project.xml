<?xml version="1.0" encoding="UTF-8"?>
<project>
  <name>wayland-rt</name>
  <!-- version inherited from aggregator -->
  <author>Andrew Haines</author>
  <license>BSD-3-Clause</license>

  <!-- Runtime Wayland binding. RTL-only: no tiOPF / json_easy dependency.
       The generated units (wayland.pas, xdg_shell.pas) live here too; they are
       produced by the separate wayland-gen tool (lazbuild). -->
  <build>
    <packaging>library</packaging>
    <outputDirectory>target</outputDirectory>
  </build>

  <profiles>
    <profile>
      <id>debug</id>
      <defines>
        <define>DEBUG</define>
      </defines>
      <compilerOptions>
        <option>-g</option>
        <option>-gl</option>
        <option>-gw3</option>
        <option>-gh</option>
      </compilerOptions>
    </profile>
  </profiles>
</project>

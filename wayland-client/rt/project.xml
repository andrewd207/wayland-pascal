<?xml version="1.0" encoding="UTF-8"?>
<project>
  <name>wayland-rt</name>
  <!-- version inherited from aggregator -->
  <author>Andrew Haines</author>
  <license>BSD-3-Clause</license>

  <!-- Client runtime: the generated client-core proxies (wayland.pas). The
       shared transport/codec lives in the wayland-common module; we compile it
       in via the unitPaths entry below (fpc compiles those units on demand) so
       wayland-common need not be a built dependency. Downstream client modules
       depend on this module and pick up the common units transitively. -->
  <build>
    <packaging>library</packaging>
    <outputDirectory>target</outputDirectory>
    <unitPaths>
      <path>src/main/pascal</path>
      <path>../../wayland-common/src/main/pascal</path>
    </unitPaths>
  </build>

  <profiles>
    <profile>
      <id>debug</id>
      <defines>
        <define>DEBUG</define>
      </defines>
      <compilerOptions>
        <option>-g</option>
        <option>-gl</option>
        <option>-gw3</option>
        <option>-gh</option>
      </compilerOptions>
    </profile>
  </profiles>
</project>

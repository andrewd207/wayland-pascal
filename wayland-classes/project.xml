<?xml version="1.0" encoding="UTF-8"?>
<project>
  <name>wayland-classes</name>
  <!-- version inherited from aggregator -->
  <author>Andrew Haines</author>
  <license>BSD-3-Clause</license>

  <!-- Higher-level OOP convenience classes built on top of the runtime
       binding. RTL-only: depends only on the core runtime (wayland-rt). -->
  <build>
    <packaging>library</packaging>
    <outputDirectory>target</outputDirectory>
  </build>

  <moduleDependencies>
    <module>../wayland-rt</module>
    <module>../wayland-stable</module>
    <module>../wayland-unstable</module>
    <module>../wayland-staging</module>
  </moduleDependencies>

  <profiles>
    <profile>
      <id>debug</id>
      <defines>
        <define>DEBUG</define>
      </defines>
      <compilerOptions>
        <option>-g</option>
        <option>-gl</option>
        <option>-gw3</option>
        <option>-gh</option>
      </compilerOptions>
    </profile>
  </profiles>
</project>

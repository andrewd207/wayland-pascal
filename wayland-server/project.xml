<?xml version="1.0" encoding="UTF-8"?>
<project>
  <name>wayland-server</name>
  <!-- version inherited from aggregator -->
  <author>Andrew Haines</author>
  <license>BSD-3-Clause</license>

  <!-- Aggregator for the server-side stack: the hand-written runtime base (rt,
       which also carries the generated server core wayland_server.pas) plus the
       generated server protocol tiers. Like the client stack it builds on the
       shared wayland-common transport. -->
  <build>
    <packaging>pom</packaging>
  </build>

  <modules>
    <module>rt</module>
    <module>stable</module>
    <module>unstable</module>
    <module>staging</module>
    <module>classes</module>
  </modules>
</project>

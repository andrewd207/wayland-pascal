<?xml version="1.0" encoding="UTF-8"?>
<project>
  <name>wayland-server-stable</name>
  <!-- version inherited from aggregator -->
  <author>Andrew Haines</author>
  <license>BSD-3-Clause</license>

  <!-- Stable wayland-protocols, generated as <protocol>_server units by the
       wayland-gen tool's server pass. Depends only on the server runtime. -->
  <build>
    <packaging>library</packaging>
    <outputDirectory>target</outputDirectory>
  </build>

  <moduleDependencies>
    <module>../rt</module>
  </moduleDependencies>

  <profiles>
    <profile>
      <id>debug</id>
      <defines>
        <define>DEBUG</define>
      </defines>
      <compilerOptions>
        <option>-g</option>
        <option>-gl</option>
        <option>-gw3</option>
        <option>-gh</option>
      </compilerOptions>
    </profile>
  </profiles>
</project>

  lId: TWlSubsurface;
  lSurface: TWlSurface;
  lParent: TWlSurface;
  lListenerIdx: Integer;
begin
  lId := TWlSubsurface.Create(Client, AMsg.Args.ReadDWord, Version);
  lSurface := (Client.GetObject(AMsg.Args.ReadDWord) as TWlSurface);
  lParent := (Client.GetObject(AMsg.Args.ReadDWord) as TWlSurface);
  if Assigned(OnGetSubsurface) then OnGetSubsurface(Self,lId,lSurface,lParent);
  for lListenerIdx := 0 to High(FListeners) do FListeners[lListenerIdx].wl_subcompositor_get_subsurface(Self,lId,lSurface,lParent);
  AMsg.SetHandled;
end;


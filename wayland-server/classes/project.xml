<?xml version="1.0" encoding="UTF-8"?>
<project>
  <name>wayland-server-classes</name>
  <!-- version inherited from aggregator -->
  <author>Andrew Haines</author>
  <license>BSD-3-Clause</license>

  <!-- Server protocol-ergonomics layer (the server-side counterpart of the
       client's wayland-classes): wl_display / wl_registry / globals / bind /
       version-clamp / sync / serial plumbing. Deliberately NOT a compositor —
       it stops at "you have a resource with a committed buffer"; what to do with
       that (compositing, scanout, input) is the app's backend. Builds on the
       server runtime + the generated core protocol (wayland_server). -->
  <build>
    <packaging>library</packaging>
    <outputDirectory>target</outputDirectory>
  </build>

  <moduleDependencies>
    <module>../rt</module>
  </moduleDependencies>

  <profiles>
    <profile>
      <id>debug</id>
      <defines>
        <define>DEBUG</define>
      </defines>
      <compilerOptions>
        <option>-g</option>
        <option>-gl</option>
        <option>-gw3</option>
        <option>-gh</option>
      </compilerOptions>
    </profile>
  </profiles>
</project>
